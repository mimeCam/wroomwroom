#!/usr/bin/env bash
#
# openloop_cc_docker - Run openloop with docker containerization
# Usage: openloop_cc_docker-base "image" "suffix" "persona" "prompt" ["system_prompt"] ["mode"]
#   4 args:  image, suffix, persona, prompt
#   5 args:  image, suffix, persona, prompt, system_prompt
#   6 args:  image, suffix, persona, prompt, system_prompt, mode
#
# Supports stdin streaming
#

# this is noop. _build_and_install_local rewrites `$DOCKER`.
DOCKER=$(whereis docker | awk '{print $2}') # if simply `docker` then this script fails to start docker when launched by openloop-runner.

IMAGE="$1"
SUFFIX="$2"

shift 2

PARENT="$1"
shift

if [ -n "$API_KEY" ] && [ -z "$API_ENDPOINT" ]; then
    echo "Error: API_ENDPOINT is required when API_KEY is set" >&2
    exit 1
fi
if [ -z "$API_KEY" ] && [ -n "$API_ENDPOINT" ]; then
    echo "Error: API_KEY is required when API_ENDPOINT is set" >&2; exit 1
fi
if [ -n "$API_KEY" ] && [ -n "$API_ENDPOINT" ]; then
    if [ "$API_KEY" = "🔥🔥🔥" ]; then
        echo "Error: API_KEY must be changed from placeholder value" >&2
        exit 1
    fi
    use_tier=false
else
    use_tier=true
fi

# Handle optional parameters
PERSONA=""
if [ $# -ge 1 ]; then
    PERSONA="$1"
fi
PROMPT=""
if [ $# -ge 2 ]; then
    PROMPT="$2"
fi
SYSTEM_PROMPT=""
if [ $# -ge 3 ]; then
    SYSTEM_PROMPT="$3"
fi
# "acceptEdits", "bypassPermissions", "default", "dontAsk", "plan", "auto"
# MODE="bypassPermissions"
MODE="bypassPermissions" # fine with --dangerously-skip-permissions?
if [ $# -ge 4 ]; then
    MODE="$4"
fi

# Validate required parameters
if [ -z "$PERSONA" ]; then
    echo "Error: PERSONA is required" >&2
    echo "Usage: $0 \"image\" \"suffix\" \"persona\" \"prompt\" [\"system_prompt\"] [\"mode\"]" >&2
    exit 1
fi

if [ -z "$PROMPT" ]; then
    echo "Error: PROMPT is required" >&2
    echo "Usage: $0 \"image\" \"suffix\" \"persona\" \"prompt\" [\"system_prompt\"] [\"mode\"]" >&2
    exit 1
fi

ROOT="$PWD"
PARENT="${PARENT:-$ROOT}"
if [[ "$PARENT" != "$HOME"/* ]]; then
    echo "ERR. PARENT must be inside \$HOME. Got: $PARENT" >&2; exit 1
fi
if [ ! -d "$ROOT/openloop" ]; then
    echo "Error: openloop directory not found in $ROOT" >&2
    exit 1
fi
# Determine MCP config path with priority
MCP_CONFIG_PATH=""
USE_STRICT_MCP=""
# if [ -f "$ROOT/openloop/personas/$PERSONA-mcp-yolo-strict.json" ]; then
#     MCP_CONFIG_PATH="$ROOT/openloop/personas/$PERSONA-mcp-yolo-strict.json"
#     USE_STRICT_MCP="--strict-mcp-config"
# elif [ -f "$ROOT/openloop/personas/$PERSONA-mcp-yolo.json" ]; then
#     MCP_CONFIG_PATH="$ROOT/openloop/personas/$PERSONA-mcp-yolo.json"
# elif [ -f "$ROOT/openloop/mcp-yolo-strict.json" ]; then
#     MCP_CONFIG_PATH="$ROOT/openloop/mcp-yolo-strict.json"
#     USE_STRICT_MCP="--strict-mcp-config"
# fi

CLAUDE_JSON="$HOME/.claude${SUFFIX}.json"
CLAUDE_JSON_BK="$HOME/.claude${SUFFIX}.json.backup"
CLAUDE_DIR="$HOME/.claude${SUFFIX}"

mkdir -p "$CLAUDE_DIR"

MODEL_ENV_FLAGS=()
[ -n "$ANTHROPIC_DEFAULT_OPUS_MODEL" ] && MODEL_ENV_FLAGS+=(-e "ANTHROPIC_DEFAULT_OPUS_MODEL=$ANTHROPIC_DEFAULT_OPUS_MODEL")
[ -n "$ANTHROPIC_DEFAULT_SONNET_MODEL" ] && MODEL_ENV_FLAGS+=(-e "ANTHROPIC_DEFAULT_SONNET_MODEL=$ANTHROPIC_DEFAULT_SONNET_MODEL")
[ -n "$ANTHROPIC_DEFAULT_HAIKU_MODEL" ] && MODEL_ENV_FLAGS+=(-e "ANTHROPIC_DEFAULT_HAIKU_MODEL=$ANTHROPIC_DEFAULT_HAIKU_MODEL")
[ -n "$CLAUDE_CODE_SUBAGENT_MODEL" ] && MODEL_ENV_FLAGS+=(-e "CLAUDE_CODE_SUBAGENT_MODEL=$CLAUDE_CODE_SUBAGENT_MODEL")

if [ ! -f "$CLAUDE_JSON" ]; then
    echo '{}' > "$CLAUDE_JSON"
fi
if [ ! -f "$CLAUDE_JSON_BK" ]; then
    echo '{}' > "$CLAUDE_JSON_BK"
fi

if [ "$use_tier" = true ]; then
    #
    # Checking your claude usage:
    # https://claude.ai/settings/usage
    #
    CLAUDE_SYNC_ITEMS=".credentials.json CLAUDE.md settings.json"
    CLAUDE_SBX=$(mktemp -d)
    [ -f "$CLAUDE_JSON" ] && cp "$CLAUDE_JSON" "$CLAUDE_SBX/.claude.json"
    [ -f "$CLAUDE_JSON_BK" ] && cp "$CLAUDE_JSON_BK" "$CLAUDE_SBX/.claude.json.backup"
    mkdir -p "$CLAUDE_SBX/.claude"
    for item in $CLAUDE_SYNC_ITEMS; do
        [ -e "$HOME/.claude/$item" ] && cp -R "$HOME/.claude/$item" "$CLAUDE_SBX/.claude/"
    done

    restore() {
        [ -f "$CLAUDE_SBX/.claude.json" ] && cp "$CLAUDE_SBX/.claude.json" "$CLAUDE_JSON"
        [ -f "$CLAUDE_SBX/.claude.json.backup" ] && cp "$CLAUDE_SBX/.claude.json.backup" "$CLAUDE_JSON_BK"
        mkdir -p "$CLAUDE_DIR"
        for item in $CLAUDE_SYNC_ITEMS; do
            [ -e "$CLAUDE_SBX/.claude/$item" ] && cp -R "$CLAUDE_SBX/.claude/$item" "$CLAUDE_DIR/"
        done
        rm -rf "$CLAUDE_SBX"
    }
    on_exit() {
        if [ $? -eq 0 ]; then
            restore
        else
            echo "ERR. Docker run failed, cc-config files NOT restored."
            rm -rf "$CLAUDE_SBX"
        fi
    }
    trap on_exit EXIT
fi

# Determine volume mounts based on mode
VOLUME_MOUNTS=()

if [ -d "$HOME/Library/Developer/Xcode/DerivedData" ]; then
    VOLUME_MOUNTS+=(-v "$HOME/Library/Developer/Xcode/DerivedData:$HOME/Library/Developer/Xcode/DerivedData:ro")
fi

[ -f "$HOME/.gitignore" ] && VOLUME_MOUNTS+=(-v "$HOME/.gitignore:/home/node/.gitignore:ro")
[ -f "$HOME/.gitconfig" ] && VOLUME_MOUNTS+=(-v "$HOME/.gitconfig:/home/node/.gitconfig:ro")

if [ "${MODE}" == "plan" ]; then
    VOLUME_MOUNTS+=(-v "$PARENT:$PARENT:ro")
else
    VOLUME_MOUNTS+=(-v "$PARENT:$PARENT")
fi

if [ "$PERSONA" == "_head_" ] || [ "$PERSONA" == "_bottom_" ]; then
    PRJ="$ROOT"

    VOLUME_MOUNTS+=(--tmpfs "$ROOT/openloop:ro")
else
    PRJ="$ROOT/openloop"

    if [[ "$PERSONA" != "$HOME"/* ]]; then
        echo "ERR. PERSONA must be inside \$HOME. Got: $PERSONA" >&2; exit 1
    fi
    VOLUME_MOUNTS+=(-v "$PERSONA:$ROOT/openloop:ro")
fi

YOLO_STDIN=""
if [ -p /dev/stdin ]; then
    YOLO_STDIN=$(cat)
fi
if [ -n "$YOLO_STDIN" ] && [ -d "$YOLO_STDIN" ]; then
    # VOLUME_MOUNTS+=(-v "$YOLO_STDIN:$PRJ/_reports:ro")
    mkdir -p $ROOT/_reports
    VOLUME_MOUNTS+=(-v "$YOLO_STDIN:$ROOT/_reports:ro")
    YOLO_STDIN=""
fi

mkdir -p "$ROOT/_my"
VOLUME_MOUNTS+=(--tmpfs "$ROOT/_my:uid=1000,gid=1000")

# Build claude command following yolo_claude.sh pattern
SKIP_PERMISSIONS_FLAG=""
# if [ "${MODE}" != "plan" ]; then # it needs to save `~/_report.md` in plan mode without asks.
    SKIP_PERMISSIONS_FLAG="--dangerously-skip-permissions"
# fi
MCP_FLAGS=""
if [ -n "$MCP_CONFIG_PATH" ]; then
    MCP_FLAGS="--mcp-config \"${MCP_CONFIG_PATH}\""
    if [ -n "$USE_STRICT_MCP" ]; then
        MCP_FLAGS="$MCP_FLAGS $USE_STRICT_MCP"
    fi
fi

# --permission-mode \"${MODE}\" \ # cc does magic internally when mode is "plan"
CLAUDE_CMD="claude ${SKIP_PERMISSIONS_FLAG} \
    --permission-mode bypassPermissions \
    --disallowed-tools \"WebSearch,WebFetch,AskUserQuestion\" \
    --no-session-persistence \
    ${MCP_FLAGS} \
    --model sonnet \
    -p \"\$PROMPT\""
    # --chrome

if [ -n "$SYSTEM_PROMPT" ]; then
    CLAUDE_CMD="$CLAUDE_CMD --system-prompt \"\$SYSTEM_PROMPT\""
    # --append-system-prompt \"\$SYSTEM_PROMPT\" \
fi

INNER_CMD="$CLAUDE_CMD > /tmp/_cc_out 2>/dev/null; [ -s \"$ROOT/_my/report.md\" ] && cat \"$ROOT/_my/report.md\" || cat /tmp/_cc_out"

if [ "$use_tier" = true ]; then
    $DOCKER run --rm \
        --pids-limit=500 \
        --init \
        -e ANTHROPIC_LOG=error \
        -e CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
        -v "$CLAUDE_SBX/.claude:/home/node/.claude" \
        -v "$CLAUDE_SBX/.claude.json:/home/node/.claude.json" \
        -v "$CLAUDE_SBX/.claude.json.backup:/home/node/.claude.json.backup" \
        -e BASH_DEFAULT_TIMEOUT_MS=20 \
        "${MODEL_ENV_FLAGS[@]}" \
        -e "PROMPT=${PROMPT}" \
        -e "SYSTEM_PROMPT=${SYSTEM_PROMPT}" \
        "${VOLUME_MOUNTS[@]}" \
        -w "$PRJ" \
        $IMAGE bash -c "$INNER_CMD"
else
    $DOCKER run --rm \
        --pids-limit=500 \
        --init \
        -v /etc/localtime:/etc/localtime:ro \
        -e ANTHROPIC_LOG=error \
        -e CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
        -e "ANTHROPIC_BASE_URL=${API_ENDPOINT}" \
        -e "ANTHROPIC_AUTH_TOKEN=${API_KEY}" \
        -e BASH_DEFAULT_TIMEOUT_MS=20 \
        "${MODEL_ENV_FLAGS[@]}" \
        -e "PROMPT=${PROMPT}" \
        -e "SYSTEM_PROMPT=${SYSTEM_PROMPT}" \
        "${VOLUME_MOUNTS[@]}" \
        -w "$PRJ" \
        $IMAGE bash -c "$INNER_CMD"
fi
