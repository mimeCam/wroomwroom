#!/usr/bin/env bash
#
# ya-swift - yolo-anthropic (one-shot): Claude code with Anthropic, swift devcontainer
#

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

PROMPT="$1"
if [ -z "$PROMPT" ]; then
    echo "Error: PROMPT is required" >&2
    echo "Usage: $0 \"your prompt here\"" >&2
    exit 1
fi

CONTAINER_NAME="ya-swift"
IMAGE="yolo_devcontainer:swift"
source "$SCRIPT_DIR/y"
